# Cloudflare Workers Environment Variables
# Copy this file to .env and fill in your actual values
# Use 'wrangler secret put <NAME>' to set secrets in production

# Paddle (EU/UK Merchant of Record)
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_VENDOR_ID=your_paddle_vendor_id

# Stripe (US/CA Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# R2 Storage (for audit logs)
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# D1 Database
# Configured via wrangler.toml, no separate credentials needed

# Application Settings
ENVIRONMENT=development
TASK_PRICING_PER_UNIT=0.05
HUMAN_REVIEW_THRESHOLD=0.95
MAX_RETRY_ATTEMPTS=3
