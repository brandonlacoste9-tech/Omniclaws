# Cloudflare Workers Environment Variables
# Copy this to .env and fill in your actual values

# Billing API Keys
PADDLE_API_KEY=your_paddle_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Optional AI Service Keys
OPENAI_API_KEY=your_openai_api_key_here

# Database IDs (replace after creating D1 database)
D1_DATABASE_ID=your_d1_database_id_here

# R2 Bucket (replace after creating R2 bucket)
R2_BUCKET_NAME=omniclaws-audit-logs

# KV Namespace ID (optional, replace after creating KV namespace)
KV_NAMESPACE_ID=your_kv_namespace_id_here
